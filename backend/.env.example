# =============================================
# 셀마이홈 백엔드 환경변수
# .env.example → .env 로 복사 후 값 입력
# =============================================

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # 서버에서만 사용 (절대 클라이언트 노출 금지)

# ── JWT ──────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ── Server ───────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── 토스페이먼츠 결제 ──────────────────────────
TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# ── Firebase FCM (푸시 알림) ──────────────────
FIREBASE_PROJECT_ID=sellmyhome
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@sellmyhome.iam.gserviceaccount.com

# ── 카카오맵 API ─────────────────────────────
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# ── 공공데이터포털 (건축물대장 자동 소유 인증) ──
# https://www.data.go.kr → 국토교통부 건축물대장정보서비스 → 활용신청 → 일반 인증키 복사
PUBLIC_DATA_API_KEY=your_public_data_api_key_url_encoded

# ── AWS S3 (선택: Supabase Storage 대신 사용 시) ──
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-2
# AWS_S3_BUCKET=sellmyhome-uploads
